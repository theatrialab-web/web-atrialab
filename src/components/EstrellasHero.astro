---
// ============================================
// ESTRELLAS HERO — campo de estrellas 3D + constelación Atria
// Único bloque WebGL del sitio, contenido en el hero.
//
// - Estrellas con tamaño y brillo variados (shader), pocas y limpias.
// - Constelación del Triángulo Austral SIN línea de base: una luz la
//   dibuja desde la nada (recorriéndola), se mantiene un momento,
//   se desvanece y vuelve a dibujarse, en bucle. Atria se ilumina
//   con fuerza cuando la luz llega a ella.
//
// Salvaguardas: carga diferida, pausa fuera de vista, menos en móvil,
// respeta "reducir movimiento", y si no hay WebGL queda el degradado.
// ============================================
---

<canvas class="hero-canvas" data-estrellas aria-hidden="true"></canvas>

<script>
  import * as THREE from 'three';

  const canvas = document.querySelector('[data-estrellas]');

  if (canvas instanceof HTMLCanvasElement) {
    const movimientoReducido = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let renderer: THREE.WebGLRenderer | null = null;
    try {
      renderer = new THREE.WebGLRenderer({
        canvas, alpha: true, antialias: true, powerPreference: 'high-performance',
      });
    } catch (e) {
      renderer = null;
    }

    if (renderer) {
      const escena = new THREE.Scene();
      const camara = new THREE.PerspectiveCamera(60, 1, 0.1, 3000);
      camara.position.z = 500;

      const pixelRatio = () => Math.min(window.devicePixelRatio, 1.8);

      function ajustarTamano() {
        const w = canvas.clientWidth, h = canvas.clientHeight;
        renderer!.setPixelRatio(pixelRatio());
        renderer!.setSize(w, h, false);
        camara.aspect = w / h;
        camara.updateProjectionMatrix();
      }

      function texturaEstrella() {
        const c = document.createElement('canvas');
        c.width = c.height = 64;
        const g = c.getContext('2d')!;
        const grad = g.createRadialGradient(32, 32, 0, 32, 32, 32);
        grad.addColorStop(0, 'rgba(255,255,255,1)');
        grad.addColorStop(0.25, 'rgba(255,255,255,0.85)');
        grad.addColorStop(1, 'rgba(255,255,255,0)');
        g.fillStyle = grad;
        g.fillRect(0, 0, 64, 64);
        return new THREE.CanvasTexture(c);
      }
      const texEstrella = texturaEstrella();

      function texturaTexto(texto: string) {
        const c = document.createElement('canvas');
        c.width = 256; c.height = 64;
        const g = c.getContext('2d')!;
        g.fillStyle = 'rgba(255,255,255,0.92)';
        g.font = '600 32px sans-serif';
        g.textAlign = 'center';
        g.textBaseline = 'middle';
        g.fillText(texto, 128, 34);
        const t = new THREE.CanvasTexture(c);
        t.needsUpdate = true;
        return t;
      }

      // ============================================================
      // 1) CAMPO DE ESTRELLAS — pocas, con tamaño y brillo variados
      // ============================================================
      const cantidad = window.innerWidth < 700 ? 450 : 850;
      const posiciones = new Float32Array(cantidad * 3);
      const colores = new Float32Array(cantidad * 3);
      const tamanos = new Float32Array(cantidad);
      const fases = new Float32Array(cantidad);

      const blanco = new THREE.Color(0xffffff);
      const morado = new THREE.Color(0x9a91ff);
      const azul = new THREE.Color(0xbcd0ff);

      for (let i = 0; i < cantidad; i++) {
        const i3 = i * 3;
        posiciones[i3]     = (Math.random() - 0.5) * 1200;
        posiciones[i3 + 1] = (Math.random() - 0.5) * 1200;
        posiciones[i3 + 2] = (Math.random() - 0.5) * 1000 - 100;
        const r = Math.random();
        const base = r > 0.85 ? morado : (r > 0.78 ? azul : blanco);
        const brillo = 0.5 + Math.random() * 0.6;
        colores[i3] = base.r * brillo; colores[i3 + 1] = base.g * brillo; colores[i3 + 2] = base.b * brillo;
        tamanos[i] = 1.0 + Math.pow(Math.random(), 4) * 7.0;
        fases[i] = Math.random() * Math.PI * 2;
      }

      const geoCampo = new THREE.BufferGeometry();
      geoCampo.setAttribute('position', new THREE.BufferAttribute(posiciones, 3));
      geoCampo.setAttribute('aColor', new THREE.BufferAttribute(colores, 3));
      geoCampo.setAttribute('aSize', new THREE.BufferAttribute(tamanos, 1));
      geoCampo.setAttribute('aPhase', new THREE.BufferAttribute(fases, 1));

      const matCampo = new THREE.ShaderMaterial({
        uniforms: {
          uTime: { value: 0 },
          uPixelRatio: { value: pixelRatio() },
          uScale: { value: 620 },
          uTexture: { value: texEstrella },
        },
        vertexShader: `
          attribute float aSize;
          attribute float aPhase;
          attribute vec3 aColor;
          uniform float uTime;
          uniform float uPixelRatio;
          uniform float uScale;
          varying vec3 vColor;
          void main() {
            float tw = 0.55 + 0.45 * sin(uTime * 1.6 + aPhase);
            vColor = aColor * (0.45 + tw * 0.85);
            vec4 mv = modelViewMatrix * vec4(position, 1.0);
            float dist = max(-mv.z, 1.0);
            gl_PointSize = aSize * (0.7 + tw * 0.6) * uPixelRatio * (uScale / dist);
            gl_PointSize = min(gl_PointSize, 48.0);
            gl_Position = projectionMatrix * mv;
          }
        `,
        fragmentShader: `
          uniform sampler2D uTexture;
          varying vec3 vColor;
          void main() {
            vec4 tex = texture2D(uTexture, gl_PointCoord);
            gl_FragColor = vec4(vColor, tex.a);
          }
        `,
        transparent: true,
        depthWrite: false,
        blending: THREE.AdditiveBlending,
      });

      const campo = new THREE.Points(geoCampo, matCampo);
      escena.add(campo);

      // ============================================================
      // 2) CONSTELACIÓN — se dibuja desde la nada, en bucle
      // ============================================================
      const constelacion = new THREE.Group();

      const A = new THREE.Vector3(0, 78, 0);    // Atria
      const B = new THREE.Vector3(-74, -42, 0); // Beta
      const C = new THREE.Vector3(74, -42, 0);  // Gamma

      function puntoPerimetro(tt: number) {
        const seg = tt * 3;
        if (seg < 1) return A.clone().lerp(B, seg);
        if (seg < 2) return B.clone().lerp(C, seg - 1);
        return C.clone().lerp(A, seg - 2);
      }

      // Una sola línea (sin base visible). Se revela con setDrawRange.
      const N = 220;
      const ptsLinea: THREE.Vector3[] = [];
      for (let i = 0; i <= N; i++) ptsLinea.push(puntoPerimetro(i / N));
      const geoLinea = new THREE.BufferGeometry().setFromPoints(ptsLinea);
      geoLinea.setDrawRange(0, 0);
      const matLinea = new THREE.LineBasicMaterial({
        color: 0xb9b2ff, transparent: true, opacity: 0,
        blending: THREE.AdditiveBlending, depthWrite: false,
      });
      constelacion.add(new THREE.Line(geoLinea, matLinea));

      function estrella(pos: THREE.Vector3, tam: number, color: number, op = 1) {
        const m = new THREE.SpriteMaterial({
          map: texEstrella, color, transparent: true, opacity: op,
          depthWrite: false, blending: THREE.AdditiveBlending,
        });
        const s = new THREE.Sprite(m);
        s.position.copy(pos);
        s.scale.set(tam, tam, 1);
        return s;
      }

      // Atria + halo + etiqueta: SIEMPRE visibles (es la estrella ancla)
      const halo = estrella(A, 95, 0x9a91ff, 0.4);
      const atria = estrella(A, 30, 0xffffff, 1);
      // Beta y Gamma: aparecen cuando la luz las alcanza
      const beta = estrella(B, 17, 0xffffff, 0);
      const gamma = estrella(C, 17, 0xffffff, 0);
      const luz = estrella(A, 22, 0xffffff, 1);
      constelacion.add(halo, atria, beta, gamma, luz);

      const matEtq = new THREE.SpriteMaterial({
        map: texturaTexto('Atria'), transparent: true, opacity: 0.78, depthWrite: false,
      });
      const etiqueta = new THREE.Sprite(matEtq);
      etiqueta.position.set(A.x + 52, A.y + 6, A.z);
      etiqueta.scale.set(72, 18, 1);
      constelacion.add(etiqueta);

      // Posición: en escritorio ancho va a la derecha-abajo (zona marcada)
      let baseY = -110;
      function colocarConstelacion() {
        const w = window.innerWidth;
        if (w < 700) {
          baseY = 200; constelacion.position.set(0, baseY, 120); constelacion.scale.setScalar(0.7);
        } else if (w < 1200) {
          baseY = -75; constelacion.position.set(180, baseY, 120); constelacion.scale.setScalar(0.9);
        } else {
          baseY = -110; constelacion.position.set(285, baseY, 120); constelacion.scale.setScalar(1);
        }
      }
      colocarConstelacion();
      escena.add(constelacion);

      ajustarTamano();
      window.addEventListener('resize', () => {
        ajustarTamano();
        colocarConstelacion();
        matCampo.uniforms.uPixelRatio.value = pixelRatio();
      });

      let raton_x = 0, raton_y = 0;
      window.addEventListener('mousemove', (e) => {
        raton_x = e.clientX / window.innerWidth - 0.5;
        raton_y = e.clientY / window.innerHeight - 0.5;
      });

      let visible = true;
      const observador = new IntersectionObserver(
        (entradas) => { visible = entradas[0].isIntersecting; },
        { threshold: 0 }
      );
      observador.observe(canvas);

      function rampa(x: number, inicio: number, ancho = 0.08) {
        return Math.min(1, Math.max(0, (x - inicio) / ancho));
      }

      // Ciclo: dibujar -> mantener -> desvanecer -> repetir
      const T_DIBUJO = 2.4, T_MANTENER = 2.0, T_FUNDIDO = 1.2;
      const CICLO = T_DIBUJO + T_MANTENER + T_FUNDIDO;
      const reloj = new THREE.Clock();

      function animar() {
        requestAnimationFrame(animar);
        if (!visible) return;
        const t = reloj.getElapsedTime();

        matCampo.uniforms.uTime.value = t;
        campo.rotation.y = t * 0.015;
        campo.rotation.x = t * 0.005;

        const cy = t % CICLO;
        let glow = 0;

        if (cy < T_DIBUJO) {
          // FASE 1: la luz dibuja el triángulo desde la nada
          const avance = cy / T_DIBUJO;
          geoLinea.setDrawRange(0, Math.floor(avance * N) + 1);
          matLinea.opacity = 0.85;
          beta.material.opacity = 0.92 * rampa(avance, 0.30);
          gamma.material.opacity = 0.92 * rampa(avance, 0.63);
          luz.visible = true;
          luz.position.copy(puntoPerimetro(avance));
          glow = Math.max(0, (avance - 0.8) / 0.2);  // Atria brilla al volver la luz
          luz.material.opacity = 1;
          luz.scale.setScalar(22 + glow * 18);
        } else if (cy < T_DIBUJO + T_MANTENER) {
          // FASE 2: triángulo formado, se mantiene un momento
          const h = (cy - T_DIBUJO) / T_MANTENER;
          geoLinea.setDrawRange(0, N + 1);
          matLinea.opacity = 0.85;
          beta.material.opacity = 0.92;
          gamma.material.opacity = 0.92;
          luz.visible = false;
          glow = Math.max(0, 1 - h * 1.7);
        } else {
          // FASE 3: se desvanece y volverá a dibujarse
          const f = (cy - T_DIBUJO - T_MANTENER) / T_FUNDIDO;
          geoLinea.setDrawRange(0, N + 1);
          matLinea.opacity = 0.85 * (1 - f);
          beta.material.opacity = 0.92 * (1 - f);
          gamma.material.opacity = 0.92 * (1 - f);
          luz.visible = false;
          glow = 0;
        }

        atria.scale.setScalar(30 + glow * 34);
        atria.material.opacity = 1;
        halo.material.opacity = 0.35 + glow * 0.5 + 0.04 * Math.sin(t * 1.6);

        constelacion.position.y = baseY + Math.sin(t * 0.6) * 6;
        constelacion.rotation.z = Math.sin(t * 0.3) * 0.025;

        camara.position.x += (raton_x * 60 - camara.position.x) * 0.03;
        camara.position.y += (-raton_y * 60 - camara.position.y) * 0.03;
        camara.lookAt(escena.position);

        renderer!.render(escena, camara);
      }

      if (movimientoReducido) {
        matCampo.uniforms.uTime.value = 1.0;
        geoLinea.setDrawRange(0, N + 1);
        matLinea.opacity = 0.6;
        beta.material.opacity = 0.92;
        gamma.material.opacity = 0.92;
        luz.visible = false;
        ajustarTamano();
        renderer.render(escena, camara);
      } else {
        animar();
      }
    }
  }
</script>
