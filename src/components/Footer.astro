---
// ============================================
// FOOTER — multicolumna, estilo agencia, con el lenguaje de marca.
// Marca + redes · Servicios · Navegación · Contacto.
// ============================================

const anio = new Date().getFullYear();
---

<footer class="pie">
  <div class="pie-top">
    <!-- Marca + redes -->
    <div class="pie-marca">
      <a href="/" class="logo" aria-label="Atria Lab — inicio">
        <img src="/LOGO_HORIZONTAL.svg" alt="Atria Lab" />
      </a>
      <p>Estrategia humana e inteligencia artificial para hacer crecer marcas en España.</p>
      <div class="pie-redes">
        <!-- Reemplaza # por tus URLs reales -->
        <a href="#" class="pie-red" aria-label="Instagram" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <rect x="3" y="3" width="18" height="18" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17" cy="7" r="1" fill="currentColor" stroke="none" />
          </svg>
        </a>
        <a href="#" class="pie-red" aria-label="LinkedIn" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M6.94 5a1.94 1.94 0 1 1-3.88 0 1.94 1.94 0 0 1 3.88 0zM3.4 8.5h3.1V21H3.4zM9 8.5h2.97v1.7h.04c.41-.78 1.42-1.6 2.93-1.6 3.13 0 3.71 2.06 3.71 4.74V21h-3.1v-5.54c0-1.32-.02-3.02-1.84-3.02-1.85 0-2.13 1.44-2.13 2.92V21H9z" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Servicios (enlazan a las anclas reales de /servicios) -->
    <nav class="pie-col" aria-label="Servicios">
      <h3>Servicios</h3>
      <a href="/servicios#contenido-con-ia">Contenido con IA</a>
      <a href="/servicios#estrategia-storytelling">Estrategia y storytelling</a>
      <a href="/servicios#paid-media">Paid media</a>
      <a href="/servicios#desarrollo-web">Desarrollo web</a>
      <a href="/servicios">Ver todos</a>
    </nav>

    <!-- Navegación -->
    <nav class="pie-col" aria-label="Navegación">
      <h3>Atria Lab</h3>
      <a href="/">Inicio</a>
      <a href="/nosotros">Nosotros</a>
      <a href="/contacto">Contacto</a>
    </nav>

    <!-- Contacto -->
    <div class="pie-col pie-empezar">
      <h3>¿Empezamos?</h3>
      <a href="mailto:theatrialab@gmail.com" class="pie-contacto-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <rect x="3" y="5" width="18" height="14" rx="2" />
          <path d="M3 7l9 6 9-6" />
        </svg>
        theatrialab@gmail.com
      </a>
      <a href="/contacto" class="boton boton-primario pie-cta">Hablemos</a>
    </div>
  </div>

  <div class="pie-legal">
    <span>© {anio} Atria Lab. Todos los derechos reservados.</span>
    <ul>
      <li><a href="/aviso-legal">Aviso legal</a></li>
      <li><a href="/privacidad">Política de privacidad</a></li>
      <li><a href="/cookies">Política de cookies</a></li>
      <li><a href="/accesibilidad">Accesibilidad</a></li>
    </ul>
  </div>
</footer>
