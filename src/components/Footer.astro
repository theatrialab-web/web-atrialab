---
// ============================================
// FOOTER — multicolumna, estilo agencia, con el lenguaje de marca.
// Marca + redes · Servicios · Navegación · Contacto.
// Bilingüe: los textos y enlaces cambian según la URL (/en/...).
// ============================================

import { idiomaDe } from '../i18n';

const anio = new Date().getFullYear();
const lang = idiomaDe(Astro.url.pathname);

const t = lang === 'en'
  ? {
      logoAria: 'Atria Lab — home', rInicio: '/en/',
      descriptor: 'Human strategy and artificial intelligence to grow brands.',
      servicios: 'Services',
      s1: 'AI content',              r1: '/en/services#ai-content',
      s2: 'Strategy & storytelling', r2: '/en/services#strategy-storytelling',
      s3: 'Paid media',              r3: '/en/services#paid-media',
      s4: 'Web development',         r4: '/en/services#web-development',
      verTodos: 'View all',          rServicios: '/en/services',
      nav: 'Atria Lab',
      inicio: 'Home', nosotros: 'About', rNosotros: '/en/about',
      contacto: 'Contact', rContacto: '/en/contact',
      empezamos: 'Ready to start?', hablemos: "Let's talk",
      derechos: 'All rights reserved.',
      legal: 'Legal notice',       rLegal: '/en/legal-notice',
      privacidad: 'Privacy policy', rPrivacidad: '/en/privacy',
      cookies: 'Cookie policy',     rCookies: '/en/cookies',
      accesibilidad: 'Accessibility', rAccesibilidad: '/en/accessibility',
    }
  : {
      logoAria: 'Atria Lab — inicio', rInicio: '/',
      descriptor: 'Estrategia humana e inteligencia artificial para hacer crecer marcas en España.',
      servicios: 'Servicios',
      s1: 'Contenido con IA',           r1: '/servicios#contenido-con-ia',
      s2: 'Estrategia y storytelling',  r2: '/servicios#estrategia-storytelling',
      s3: 'Paid media',                 r3: '/servicios#paid-media',
      s4: 'Desarrollo web',             r4: '/servicios#desarrollo-web',
      verTodos: 'Ver todos',            rServicios: '/servicios',
      nav: 'Atria Lab',
      inicio: 'Inicio', nosotros: 'Nosotros', rNosotros: '/nosotros',
      contacto: 'Contacto', rContacto: '/contacto',
      empezamos: '¿Empezamos?', hablemos: 'Hablemos',
      derechos: 'Todos los derechos reservados.',
      legal: 'Aviso legal',              rLegal: '/aviso-legal',
      privacidad: 'Política de privacidad', rPrivacidad: '/privacidad',
      cookies: 'Política de cookies',       rCookies: '/cookies',
      accesibilidad: 'Accesibilidad',       rAccesibilidad: '/accesibilidad',
    };
---

<footer class="pie">
  <div class="pie-top">
    <!-- Marca + redes -->
    <div class="pie-marca">
      <a href={t.rInicio} class="logo" aria-label={t.logoAria}>
        <img src="/LOGO_HORIZONTAL.svg" alt="Atria Lab" />
      </a>
      <p>{t.descriptor}</p>
      <div class="pie-redes">
        <!-- Reemplaza # por tus URLs reales -->
        <a href="#" class="pie-red" aria-label="Instagram" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <rect x="3" y="3" width="18" height="18" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17" cy="7" r="1" fill="currentColor" stroke="none" />
          </svg>
        </a>
        <a href="#" class="pie-red" aria-label="LinkedIn" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M6.94 5a1.94 1.94 0 1 1-3.88 0 1.94 1.94 0 0 1 3.88 0zM3.4 8.5h3.1V21H3.4zM9 8.5h2.97v1.7h.04c.41-.78 1.42-1.6 2.93-1.6 3.13 0 3.71 2.06 3.71 4.74V21h-3.1v-5.54c0-1.32-.02-3.02-1.84-3.02-1.85 0-2.13 1.44-2.13 2.92V21H9z" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Servicios (enlazan a las anclas reales) -->
    <nav class="pie-col" aria-label={t.servicios}>
      <h3>{t.servicios}</h3>
      <a href={t.r1}>{t.s1}</a>
      <a href={t.r2}>{t.s2}</a>
      <a href={t.r3}>{t.s3}</a>
      <a href={t.r4}>{t.s4}</a>
      <a href={t.rServicios}>{t.verTodos}</a>
    </nav>

    <!-- Navegación -->
    <nav class="pie-col" aria-label={t.nav}>
      <h3>{t.nav}</h3>
      <a href={t.rInicio}>{t.inicio}</a>
      <a href={t.rNosotros}>{t.nosotros}</a>
      <a href={t.rContacto}>{t.contacto}</a>
    </nav>

    <!-- Contacto -->
    <div class="pie-col pie-empezar">
      <h3>{t.empezamos}</h3>
      <a href="mailto:theatrialab@gmail.com" class="pie-contacto-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <rect x="3" y="5" width="18" height="14" rx="2" />
          <path d="M3 7l9 6 9-6" />
        </svg>
        theatrialab@gmail.com
      </a>
      <a href={t.rContacto} class="boton boton-primario pie-cta">{t.hablemos}</a>
    </div>
  </div>

  <div class="pie-legal">
    <span>© {anio} Atria Lab. {t.derechos}</span>
    <ul>
      <li><a href={t.rLegal}>{t.legal}</a></li>
      <li><a href={t.rPrivacidad}>{t.privacidad}</a></li>
      <li><a href={t.rCookies}>{t.cookies}</a></li>
      <li><a href={t.rAccesibilidad}>{t.accesibilidad}</a></li>
    </ul>
  </div>
</footer>
