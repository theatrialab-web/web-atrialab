---
// ============================================
// PAGE — COOKIE POLICY (ENGLISH)
// TEMPLATE: declare only the cookies the site actually uses.
// Includes a button to revoke consent (reopens the banner).
// ============================================
import Layout from '../../layouts/Layout.astro';

const pageTitle = "Cookie policy";
const pageDescription =
  "Which cookies Atria Lab uses and how you can manage them.";
const actualizado = "July 2026";
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="pagina-hero">
    <span class="pagina-eyebrow">Legal</span>
    <h1 class="texto-degradado">Cookie policy</h1>
  </section>

  <p class="legal-nota">
    <strong>Template pending completion.</strong> Declare here only the
    cookies the site actually uses. As long as you don't load analytics or
    external tools, there will only be technical cookies. Have it reviewed
    by a professional before publishing.
  </p>

  <section class="legal">
    <p class="legal-fecha">Last updated: {actualizado}</p>

    <h2>1. What cookies are</h2>
    <p>
      A cookie is a small file a website stores in your browser to remember
      information about your visit. Some are essential for the site to work;
      others are used for measurement or personalization.
    </p>

    <h2>2. Cookies we use</h2>
    <h3>Technical (necessary)</h3>
    <p>
      We locally store your decision about the cookie notice
      (<strong>atria-cookies-consent</strong>) so we don't show it again on
      every visit. It is essential and does not require consent.
    </p>
    <h3>Analytics or third-party (optional)</h3>
    <p>
      <span class="dato">[If you enable Google Analytics, Meta Pixel or
      others, describe them here: name, provider, purpose and duration.]</span>{" "}
      These cookies are only loaded if you give your consent.
    </p>

    <h2>3. How to manage your preferences</h2>
    <p>
      You can accept or reject non-essential cookies from the initial notice,
      and change your decision whenever you want:
    </p>
    <p>
      <button type="button" class="cookie-reset" data-reset-cookies>
        Change my cookie preferences
      </button>
    </p>
    <p>
      You can also block or delete cookies from your browser settings. Note
      that disabling technical cookies may affect how the site works.
    </p>
  </section>

  <script>
    // Revokes stored consent and reloads: the banner shows again.
    document.querySelector('[data-reset-cookies]')?.addEventListener('click', () => {
      try { localStorage.removeItem('atria-cookies-consent'); } catch (e) {}
      location.reload();
    });
  </script>
</Layout>
