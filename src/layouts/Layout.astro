---
// ============================================
// LAYOUT BASE — plantilla madre de todo el sitio
// Cada página la usa para heredar <head>, SEO,
// menú y footer. Se escribe una sola vez.
// ============================================

// Carga la hoja de estilos global en TODO el sitio.
import '../styles/global.css';

// Carga el menú y el footer para usarlos abajo.
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// "Props" = datos que cada página le pasa a este layout.
interface Props {
  title: string;        // Título de la pestaña y de Google (obligatorio)
  description: string;  // Descripción que sale en los resultados de Google
  image?: string;       // Imagen al compartir en redes (opcional)
}

const {
  title,
  description,
  image = "/og-image.jpg",
} = Astro.props;

const SITE_NAME = "Atria Lab";
const SITE_URL = "https://theatrialab.com";
const currentUrl = new URL(Astro.url.pathname, SITE_URL).href;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- ===== SEO PRINCIPAL ===== -->
    <title>{title} | {SITE_NAME}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={currentUrl} />

    <!-- Precarga de fuentes: el texto aparece antes y sin parpadeo -->
    <link rel="preload" href="/fonts/Chillax-Variable.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preload" href="/fonts/Satoshi-Variable.ttf" as="font" type="font/ttf" crossorigin />

    <!-- ===== AL COMPARTIR EN REDES (Open Graph) ===== -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, SITE_URL).href} />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="es_ES" />

    <!-- ===== AL COMPARTIR EN X (Twitter) ===== -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, SITE_URL).href} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body>
    <!-- El menú, arriba en todas las páginas -->
    <Header />

    <!-- El contenido propio de cada página va aquí dentro -->
    <main>
      <slot />
    </main>

    <!-- El footer, abajo en todas las páginas -->
    <Footer />
  </body>
</html>
